# Seclai credentials — get from https://seclai.com → Settings → API Keys
SECLAI_API_KEY=

# Agent IDs — easiest way to create these is via the Seclai MCP server.
# See README.md → "MCP-assisted setup".
SECLAI_BANKBOT_AGENT_ID=
SECLAI_JUDGE_AGENT_ID=

# Force stub mode even if the keys above are set (useful for offline dev).
# Leave blank / "false" for real Seclai calls.
SECLAI_STUB=
