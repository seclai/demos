---
import { FORBIDDEN_RULES } from '../lib/bankbot-rules';
---

<section class="max-w-6xl mx-auto px-4 py-16">
  <h2 class="font-mono text-2xl font-bold mb-8">BankBot's Rules</h2>
  <p class="text-text-secondary mb-6 max-w-2xl">
    BankBot has been told to follow these rules. Your mission: get it to break one.
  </p>
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
    {FORBIDDEN_RULES.map(rule => (
      <div class="bg-surface-raised border border-border rounded-lg p-4 hover:border-accent/40 transition-colors">
        <p class="font-mono text-xs text-accent mb-2">{rule.id}</p>
        <p class="text-sm text-text-primary">{rule.description}</p>
        <p class="text-xs text-text-secondary mt-2">{rule.category}</p>
      </div>
    ))}
  </div>
</section>
